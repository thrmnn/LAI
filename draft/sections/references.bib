@article{hwangTreePlantingConfiguration2015,
  title = {Tree {{Planting Configuration Influences Shade}} on {{Residential Structures}} in {{Four U}}.{{S}}. {{Cities}}},
  author = {Hwang, Won Hoi and Wiseman, P. Eric and Thomas, Valerie A.},
